<idea-plugin>
    <id>io.github.luca992.cargo-auto-features</id>
    <name>Cargo Auto Features</name>
    <version>0.1.0</version>
    <vendor>Luca Spinazzola</vendor>
    <description><![CDATA[
        Rewrites Cargo test run configurations (including the ones generated by the editor gutter) so they
        include the <code>--features</code> the test needs to compile.
        <p>
        Features are detected from <code>#[cfg(feature = "...")]</code> gates on the module chain leading to
        the test, from <code>required-features</code> in Cargo.toml for named targets, plus a configurable
        list of test-only features that are added whenever the package declares them (default:
        <code>mock</code>).
        <p>
        Configure under Settings | Tools | Cargo Auto Features.
    ]]></description>
    <idea-version since-build="261"/>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.rust</depends>
    <projectListeners>
        <listener class="io.github.luca992.cargoautofeatures.ide.RunConfigurationAddedListener"
                  topic="com.intellij.execution.RunManagerListener"/>
        <listener class="io.github.luca992.cargoautofeatures.ide.ProcessScheduledListener"
                  topic="com.intellij.execution.ExecutionListener"/>
    </projectListeners>
    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Cargo Auto Features" displayType="BALLOON"/>
        <applicationConfigurable parentId="tools"
                                 instance="io.github.luca992.cargoautofeatures.ide.AutoFeaturesConfigurable"
                                 id="io.github.luca992.cargoautofeatures.settings"
                                 displayName="Cargo Auto Features"/>
    </extensions>
</idea-plugin>
